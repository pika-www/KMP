TEAM_ID=
PRODUCT_NAME=Androidios
PRODUCT_BUNDLE_IDENTIFIER=com.example.androidios.Androidios$(TEAM_ID)

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// --- 添加以下内容 ---

