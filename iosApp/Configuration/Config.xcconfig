USER_HEADER_SEARCH_PATHS = $(inherited)

// 修改为这个路径 (注意 bin 目录结构)
FRAMEWORK_SEARCH_PATHS = $(inherited) "$(SRCROOT)/../composeApp/build/bin/iosSimulatorArm64/debugFramework"
OTHER_LDFLAGS = $(inherited) -framework ComposeApp
